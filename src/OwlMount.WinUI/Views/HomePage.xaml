<Page
    x:Class="OwlMount.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OwlMount.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter" />
        <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
        <DataTemplate x:Key="MountItemTemplate" x:DataType="local:MountEntry">
            <Border
                x:Name="CardRoot"
                Padding="16,12"
                AutomationProperties.Name="{x:Bind Label}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                RightTapped="MountCard_RightTapped">
                <Border.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="False" />
                    </TransitionCollection>
                </Border.Transitions>
                <FlyoutBase.AttachedFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            x:Name="EditFlyoutItem"
                            Click="EditFlyoutItem_Click"
                            Text="Edit">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Edit" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Click="BrowseFlyoutItem_Click" Text="Browse">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="OpenLocal" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Click="EnableFlyoutItem_Click" Text="Enable">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE768;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Click="DisableFlyoutItem_Click" Text="Disable">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8D8;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Click="UnmountFlyoutItem_Click" Text="Unmount">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Click="PropertiesFlyoutItem_Click" Text="Properties">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE946;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </FlyoutBase.AttachedFlyout>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                        Grid.Column="0"
                        MinWidth="0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Select mount"
                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <SymbolIcon Symbol="SaveLocal" />
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DriveLetter}" />
                    </StackPanel>
                    <Border
                        Grid.Column="2"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{x:Bind IsEnabled, Converter={StaticResource BoolToStatusColorConverter}}"
                        CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="White" />
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{x:Bind IsEnabled, Converter={StaticResource BoolToStatusTextConverter}}" />
                        </StackPanel>
                    </Border>
                    <TextBlock
                        Grid.Column="3"
                        MinWidth="120"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{x:Bind Label}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind Capacity}" />
                    <TextBlock
                        Grid.Column="5"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ProviderDisplay}" />
                </Grid>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="HoverStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Target="CardRoot.Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Target="CardRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="20">
        <ListView
            x:Name="MountsListView"
            MinHeight="120"
            HorizontalContentAlignment="Stretch"
            AutomationProperties.Name="Active mounts"
            ItemTemplate="{StaticResource MountItemTemplate}"
            ItemsSource="{x:Bind ViewModel.Mounts}"
            SelectionMode="None">

            <ListView.Header>
                <StackPanel Margin="0,0,0,12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Mounts" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            AutomationProperties.Name="Add mount"
                            Command="{x:Bind ViewModel.AddMountCommand}"
                            Content="Add mount" />
                    </Grid>
                </StackPanel>
            </ListView.Header>

            <ListView.Footer>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </ListView.Footer>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <StackPanel
            x:Name="EmptyStatePanel"
            Margin="0,24,0,24"
            HorizontalAlignment="Center"
            Spacing="10"
            Visibility="Collapsed">
            <SymbolIcon HorizontalAlignment="Center" Symbol="Folder" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="18"
                FontWeight="SemiBold"
                Text="No mounts yet" />
            <TextBlock
                Width="280"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Create your first mount to see it listed here."
                TextWrapping="Wrap" />
            <Button
                HorizontalAlignment="Center"
                Command="{x:Bind ViewModel.AddMountCommand}"
                Content="Add mount" />
        </StackPanel>
    </Grid>
</Page>
