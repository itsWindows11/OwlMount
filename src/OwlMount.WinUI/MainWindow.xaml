<Window
    x:Class="OwlMount.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OwlMount.WinUI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OwlMount">

    <!--
        RootGrid has two columns:
          FormColumn   – always visible, contains the scrollable configuration form
          MountsPanelColumn – width=0 in narrow/normal; grows to * in wide mode

        VisualStateManager drives three responsive breakpoints.
    -->
    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!--
                Shared DataTemplate for both the inline list (narrow/normal) and the
                side panel (wide). Star columns keep it readable at any list width.
            -->
            <DataTemplate x:Key="MountItemTemplate" x:DataType="local:MountEntry">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="56" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" MinWidth="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- Disk icon + drive letter -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE9C4;" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind DriveLetter}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{x:Bind Label}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="{x:Bind Provider}" />
                    <TextBlock Grid.Column="3" Text="{x:Bind State}" Opacity="0.75" />
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutStates">

                <!-- Narrow: < 560 px — compact labels, stacked buttons, inline mount list -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LabelColumn.Width" Value="Auto" />
                        <Setter Target="ActionButtonsPanel.Orientation" Value="Vertical" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Normal: 560–899 px — fixed-width labels, horizontal buttons, inline list -->
                <VisualState x:Name="NormalState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="560" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LabelColumn.Width" Value="160" />
                        <Setter Target="ActionButtonsPanel.Orientation" Value="Horizontal" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Wide: ≥ 900 px — two-column layout; mounts panel slides in on the right -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LabelColumn.Width" Value="160" />
                        <Setter Target="ActionButtonsPanel.Orientation" Value="Horizontal" />
                        <Setter Target="FormColumn.Width" Value="460" />
                        <Setter Target="MountsPanelColumn.Width" Value="*" />
                        <Setter Target="SideMountsPanel.Visibility" Value="Visible" />
                        <Setter Target="InlineMountsSection.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FormColumn" Width="*" MinWidth="280" />
            <ColumnDefinition x:Name="MountsPanelColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <controls:TitleBar
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Title="OwlMount"
            Subtitle="Mount OwlCore.Storage providers as Windows drive letters."
            IsBackButtonVisible="False"
            IsPaneButtonVisible="False" />

        <!-- ── Form column (always visible) ───────────────────────────────── -->
        <ScrollViewer Grid.Row="1" Grid.Column="0">
            <StackPanel Spacing="16" Padding="20">
                <!-- Provider / backend options -->
                <Grid ColumnSpacing="12" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LabelColumn" Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Provider" />
                    <ComboBox
                        x:Name="ProviderComboBox"
                        Grid.Row="0" Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="ProviderComboBox_SelectionChanged">
                        <ComboBoxItem Content="memory" />
                        <ComboBoxItem Content="archive" />
                        <ComboBoxItem Content="local" />
                        <ComboBoxItem Content="kubo-mfs" />
                        <ComboBoxItem Content="kubo-ipfs" />
                        <ComboBoxItem Content="kubo-ipns" />
                        <ComboBoxItem Content="s3" />
                        <ComboBoxItem Content="nfs" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Backend" />
                    <ComboBox
                        x:Name="BackendComboBox"
                        Grid.Row="1" Grid.Column="1"
                        HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="winfsp" />
                        <ComboBoxItem Content="projfs" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Drive letters" />
                    <TextBox x:Name="DriveLettersTextBox" Grid.Row="2" Grid.Column="1" PlaceholderText="M, R, X" />

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Label (optional)" />
                    <TextBox x:Name="LabelTextBox" Grid.Row="3" Grid.Column="1" PlaceholderText="OwlMount (Memory)" />
                </Grid>

                <CheckBox x:Name="ReadOnlyCheckBox" Content="Read-only" />
                <CheckBox
                    x:Name="SaveMountConfigurationsCheckBox"
                    Content="Save mount point configurations"
                    IsChecked="True"
                    Checked="SaveMountConfigurationsCheckBox_Changed"
                    Unchecked="SaveMountConfigurationsCheckBox_Changed" />
                <CheckBox
                    x:Name="PersistMemoryFsOnExitCheckBox"
                    Content="Persist in-memory filesystem files on exit"
                    IsChecked="False"
                    Checked="PersistMemoryFsSettings_Changed"
                    Unchecked="PersistMemoryFsSettings_Changed" />
                <TextBox
                    x:Name="PersistMemoryFsPathTextBox"
                    PlaceholderText="Path for in-memory filesystem export"
                    LostFocus="PersistMemoryFsSettings_Changed" />

                <Expander x:Name="LocalOrArchiveExpander" Header="Local/Archive" HorizontalAlignment="Stretch" IsExpanded="True">
                    <StackPanel Spacing="8" Padding="0,8,0,0">
                        <TextBox x:Name="PathTextBox" PlaceholderText="--path (local)" />
                        <TextBox x:Name="ArchiveFileTextBox" PlaceholderText="--archive-file (archive)" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="KuboExpander" Header="Kubo" HorizontalAlignment="Stretch" IsExpanded="False">
                    <StackPanel Spacing="8" Padding="0,8,0,0">
                        <TextBox x:Name="ApiUrlTextBox" PlaceholderText="--api-url (optional)" />
                        <TextBox x:Name="CidTextBox" PlaceholderText="--cid (kubo-ipfs)" />
                        <TextBox x:Name="IpnsTextBox" PlaceholderText="--ipns (kubo-ipns)" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="S3Expander" Header="Amazon S3" HorizontalAlignment="Stretch" IsExpanded="False">
                    <StackPanel Spacing="8" Padding="0,8,0,0">
                        <TextBox x:Name="S3BucketTextBox" PlaceholderText="--bucket" />
                        <TextBox x:Name="S3PrefixTextBox" PlaceholderText="--prefix (optional)" />
                        <TextBox x:Name="S3AccessKeyTextBox" PlaceholderText="--access-key (optional)" />
                        <PasswordBox x:Name="S3SecretKeyTextBox" PlaceholderText="--secret-key (optional)" />
                        <TextBox x:Name="S3RegionTextBox" PlaceholderText="--region (optional)" />
                        <TextBox x:Name="S3EndpointTextBox" PlaceholderText="--endpoint (optional)" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="NfsExpander" Header="NFS" HorizontalAlignment="Stretch" IsExpanded="False">
                    <StackPanel Spacing="8" Padding="0,8,0,0">
                        <TextBox x:Name="NfsHostTextBox" PlaceholderText="--host" />
                        <TextBox x:Name="NfsExportTextBox" PlaceholderText="--export" />
                        <TextBox x:Name="NfsPathTextBox" PlaceholderText="--nfs-path (optional, default /)" />
                    </StackPanel>
                </Expander>

                <!-- Action buttons — Orientation switches via VisualStateManager -->
                <StackPanel x:Name="ActionButtonsPanel" Orientation="Horizontal" Spacing="8">
                    <Button Content="Mount" Click="MountButton_Click" />
                    <Button Content="Refresh" Click="RefreshButton_Click" />
                    <Button Content="Unmount selected" Click="UnmountSelectedButton_Click" />
                    <Button Content="Exit" Click="ExitButton_Click" />
                </StackPanel>

                <!--
                    Inline mounts section — visible in narrow/normal mode.
                    Hidden in wide mode; the side panel takes over.
                -->
                <StackPanel x:Name="InlineMountsSection" Spacing="8">
                    <TextBlock Text="Active mounts" FontSize="18" FontWeight="SemiBold" />
                    <ListView
                        x:Name="MountsListView"
                        MinHeight="80"
                        SelectionMode="Multiple"
                        ItemsSource="{x:Bind Mounts}"
                        ItemTemplate="{StaticResource MountItemTemplate}" />
                    <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock Text="Tip: closing this window minimizes OwlMount to the system tray." Opacity="0.55" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Side mounts panel (wide mode only, MountsPanelColumn) ───────── -->
        <Grid
            x:Name="SideMountsPanel"
            Grid.Row="1"
            Grid.Column="1"
            Visibility="Collapsed"
            Padding="12,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="Active mounts"
                FontSize="18"
                FontWeight="SemiBold"
                Margin="0,0,0,8" />

            <ListView
                Grid.Row="1"
                x:Name="MountsListViewSide"
                SelectionMode="Multiple"
                ItemsSource="{x:Bind Mounts}"
                ItemTemplate="{StaticResource MountItemTemplate}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,8,0,0"
                Text="{x:Bind StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap"
                Opacity="0.85" />

            <TextBlock
                Grid.Row="3"
                Text="Tip: closing this window minimizes OwlMount to the system tray."
                Opacity="0.55"
                FontSize="12" />
        </Grid>

    </Grid>
</Window>
